{
  "name": "invoice-parsing",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-11",
  "placement": {
    "mode": "smart"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "invoice-api.apps.ai-labs.es",
      "custom_domain": true
    }
  ],
  "containers": [
    {
      "class_name": "InvoiceParsingContainer",
      "image": "./Dockerfile.cloudflare",
      "max_instances": 10,
      "name": "invoice-parsing-container"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "InvoiceParsingContainer",
        "name": "INVOICE_PARSING"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["InvoiceParsingContainer"]
    }
  ],
  "kv_namespaces": [
    {
      "binding": "INVOICE_CACHE",
      "id": "32bf6807e6c74821a5659f9299e81f0b"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "MAX_FILE_SIZE_MB": "10",
    "CACHE_ENABLED": "true",
    "CACHE_TTL": "86400",
    "REQUEST_TIMEOUT": "120",
    "GEMINI_MODEL_NAME": "gemini-2.5-flash"
  }
}